# ── Discord ────────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=        # Bot token from Discord Developer Portal
DISCORD_PUBLIC_KEY=       # App public key (for interaction signature verification)
DISCORD_CHANNEL_ID=       # Channel where price alerts are sent
DISCORD_STOCK_CHANNEL_ID= # Channel for stock alerts (optional, defaults to above)
DISCORD_PRICE_ROLE_ID=    # Role to ping on price alerts (optional)
DISCORD_STOCK_ROLE_ID=    # Role to ping on stock alerts (optional)
DISCORD_ALLOWED_ROLES=    # Comma-separated role IDs that can approve/decline (blank = everyone)
DISCORD_ADMIN_USER_ID=    # Your Discord user ID for $approveall / $declineall

# ── Store backend — pick ONE ───────────────────────────────────────────────────
STORE_ADAPTER=shopify     # "shopify" or "custom"

# If STORE_ADAPTER=shopify:
SHOPIFY_STORE=            # yourstore.myshopify.com
SHOPIFY_TOKEN=            # Admin API access token (needs read_products + write_products)

# If STORE_ADAPTER=custom:
CUSTOM_STORE_URL=         # https://yoursite.com/api/update-price
CUSTOM_STORE_TOKEN=       # Bearer token your API validates

# ── Persistence (optional — local JSON files used if blank) ───────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Pricing behaviour ─────────────────────────────────────────────────────────
CHECK_INTERVAL=600        # Seconds between checks (default: 10 min)
UNDERCUT_PERCENT=0.01     # Undercut StarPets by this fraction (default: 1%)
RAISE_THRESHOLD=0.20      # Alert to raise price when SP is this % higher (default: 20%)
PRICE_STABILITY_MINUTES=15 # Price must hold this many minutes before alerting
PRICE_STABILITY_BUFFER=0.03 # ±$ tolerance for "same price"

# ── Security ──────────────────────────────────────────────────────────────────
API_SECRET=               # Protects /reset endpoints (set this!)
PORT=3000
